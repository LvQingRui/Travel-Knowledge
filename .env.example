# 复制为 .env 后填入真实配置（.env 含密钥，切勿提交到 Git）
# cp .env.example .env

# 服务器地址（本地开发时填阿里云公网 IP）
SERVER_HOST=你的服务器IP

# Milvus
MILVUS_HOST=你的服务器IP
MILVUS_PORT=19530

# MongoDB
MONGO_HOST=你的服务器IP
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=mongo123456

# MinIO
MINIO_HOST=你的服务器IP
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# LLM API
DASHSCOPE_API_KEY=你的通义千问API密钥
DEEPSEEK_API_KEY=你的DeepSeek密钥

# 问答 LLM 配置（默认 DeepSeek）
LLM_PROVIDER=deepseek
CHAT_MODEL=deepseek-chat

# BGE 本地模型
HF_ENDPOINT=https://hf-mirror.com
BGE_MODEL_PATH=./app/models/bge-m3
RERANKER_MODEL_PATH=./app/models/bge-reranker-large
